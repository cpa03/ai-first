# ============================================================
# Cloudflare Workers Static Asset Headers
# ============================================================
# This file configures HTTP headers for static assets served by Cloudflare.
# These headers improve performance through caching and enhance security.
#
# @see https://opennext.js.org/cloudflare/perf
# @see https://developers.cloudflare.com/pages/platform/headers
# @see https://developer.mozilla.org/en-US/docs/Web/HTTP/CSP
# ============================================================

# Next.js static chunks - aggressive caching for better performance
# These files have content hashes in names, so they are immutable
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

# Main pages - security headers with CSP
# Security headers follow Cloudflare best practices:
# @see https://developers.cloudflare.com/pages/platform/headers
# @see https://developer.mozilla.org/en-US/docs/Web/HTTP/Headers
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  X-XSS-Protection: 0
  X-Permitted-Cross-Domain-Policies: none
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), browsing-topics=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()
  # HSTS: Force HTTPS for 1 year, include subdomains, preload to browser lists
  # Only enable after confirming HTTPS works correctly for all resources
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  # COOP: Isolate browsing context to prevent cross-origin attacks
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  # CORP: Prevent cross-origin resource leaks
  Cross-Origin-Resource-Policy: same-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' https://api.openai.com https://api.anthropic.com https://*.supabase.co wss://*.supabase.co https://api.notion.com https://api.trello.com https://api.github.com; frame-ancestors 'none'; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'self'

# Static assets (images, fonts, etc.)
/_next/image
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800
  X-Content-Type-Options: nosniff

# Favicon - cache for 1 week
/favicon.ico
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400
  X-Content-Type-Options: nosniff

/favicon.svg
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400
  X-Content-Type-Options: nosniff

# Fonts - long-term caching
/*.woff2
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *
  X-Content-Type-Options: nosniff

/*.woff
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *
  X-Content-Type-Options: nosniff

# Robots.txt and sitemap - short caching
/robots.txt
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400
  Content-Type: text/plain; charset=utf-8

/sitemap.xml
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400
  Content-Type: application/xml; charset=utf-8

# API routes - no caching, security headers
/api/*
  Cache-Control: no-store, no-cache, must-revalidate, proxy-revalidate
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  X-XSS-Protection: 0
  X-Permitted-Cross-Domain-Policies: none
  Referrer-Policy: strict-origin-when-cross-origin
  # HSTS: Force HTTPS for API routes
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  # COOP: Isolate browsing context
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  # CORP: Prevent cross-origin resource leaks
  Cross-Origin-Resource-Policy: same-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' https://api.openai.com https://api.anthropic.com https://*.supabase.co https://api.notion.com https://api.trello.com https://api.github.com; frame-ancestors 'none'; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'self'

# Health check endpoints - short caching for load balancers
/api/health
  Cache-Control: public, max-age=5
  X-Content-Type-Options: nosniff

/api/health/live
  Cache-Control: public, max-age=5
  X-Content-Type-Options: nosniff

/api/health/ready
  Cache-Control: public, max-age=5
  X-Content-Type-Options: nosniff
