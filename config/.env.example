# ==========================================
# REQUIRED ENVIRONMENT VARIABLES
# ==========================================

# Application Version (Optional)
# Allows for dynamic versioning in different deployment environments
# If not set, defaults to '1.0.0'
APP_VERSION=1.0.0

# Application URLs (Optional)
# Configure custom domain URLs for your deployment
# APP_BASE_URL=https://ideaflow.ai
# APP_SITE_URL=https://ideaflow.ai
# APP_WWW_URL=https://www.ideaflow.ai
# APP_SUPPORT_EMAIL=support@ideaflow.ai
# APP_TWITTER_HANDLE=@ideaflowai

# Supabase Configuration (REQUIRED)
# ⚠️ SECURITY WARNING: See SECURITY.md for proper handling
# These NEXT_PUBLIC_* variables are safe for client-side use
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ⚠️ CRITICAL SECURITY: SUPABASE_SERVICE_ROLE_KEY
# This key bypasses ALL Row Level Security (RLS) policies.
# It grants FULL ADMIN ACCESS to the database.
# 
# SECURITY REQUIREMENTS:
# - NEVER prefix with NEXT_PUBLIC_ (would expose to client bundle)
# - NEVER use in client components or browser code
# - ONLY use in server-side contexts (API routes, server components)
# - See src/lib/db.ts for secure usage patterns
# - See SECURITY.md for full security documentation
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# AI Provider Configuration (at least one REQUIRED)
# Choose ONE of the following or include both for fallback
#
# 🔐 SECURITY BEST PRACTICES for AI Provider Keys:
# - Minimum key length: 32 characters
# - Rotate keys every 90 days
# - Use project-specific keys (not personal keys)
# - Restrict key scopes to minimum required permissions
# - Never commit actual keys to version control
# - Use different keys for dev/staging/production environments
# - Monitor API usage for anomalies
# - Revoke compromised keys immediately
OPENAI_API_KEY=sk-your-openai-api-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Cost Guardrails (REQUIRED)
COST_LIMIT_DAILY=10.0

# Application Configuration (REQUIRED)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==========================================
# OPTIONAL EXPORT INTEGRATIONS
# ==========================================
# Only configure these if you plan to use export features

# Notion Integration
NOTION_API_KEY=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=
NOTION_PARENT_PAGE_ID=

# Trello Integration
TRELLO_API_KEY=
TRELLO_TOKEN=
TRELLO_REDIRECT_URI=

# Google Tasks Integration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_REFRESH_TOKEN=

# GitHub Projects Integration
GITHUB_TOKEN=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=

# Admin Configuration
# ⚠️ SECURITY WARNING: ADMIN_API_KEY
# This key protects administrative endpoints (detailed health checks, etc.)
#
# 🔐 SECURITY REQUIREMENTS:
# - Minimum length: 32 characters
# - Must contain: uppercase, lowercase, numbers, special characters
# - Rotate every 90 days
# - Use different keys for each environment
# - Never log or expose this key in error messages
# - Store securely in your deployment platform's secrets manager
#
# Generate a secure key: openssl rand -base64 32
ADMIN_API_KEY=your-admin-api-key-for-protected-routes

# CORS Configuration (comma-separated list of allowed origins)
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

