# ==========================================
# LOGGING CONFIGURATION (Optional)
# ==========================================
# Production logging configuration for reliability and debugging
# See: docs/reliability-engineer.md for full documentation

# Log Level (Optional)
# Controls verbosity of application logs
# Valid values: DEBUG, INFO, WARN, ERROR
# Default: INFO (recommended for production)
# Use DEBUG for troubleshooting, WARN/ERROR for quieter operation
# LOG_LEVEL=INFO

# Structured Logging (Recommended for production)
# When enabled, logs are output as JSON for log aggregation services
# Useful for: CloudWatch, Datadog, Splunk, ELK stack
# STRUCTURED_LOGGING=true

# Emergency Debug Mode (Use sparingly)
# Enables debug-level logs in production for troubleshooting
# ⚠️ WARNING: Only enable temporarily during incident response
# Set to 'true' then set back to 'false' after debugging
# ENABLE_DEBUG_LOGS=false

# Build Log Suppression
# Suppresses non-error logs during build to improve Lighthouse scores
# Automatically set during npm run build
# SUPPRESS_BUILD_LOGS=true

# ==========================================
# SECURITY CONFIGURATION (Optional)
# ==========================================
# Security headers configuration for production deployments
# See: src/lib/config/constants.ts for SECURITY_CONFIG defaults

# HSTS (HTTP Strict Transport Security)
# Maximum age in seconds (default: 31536000 = 1 year)
# SECURITY_HSTS_MAX_AGE=31536000

# Include subdomains in HSTS (default: true)
# SECURITY_HSTS_INCLUDE_SUBDOMAINS=true

# Enable HSTS preload list submission (default: true)
# SECURITY_HSTS_PRELOAD=true

# Additional Security Headers
# SECURITY_CORP=same-origin
# SECURITY_COOP=same-origin-allow-popups
# SECURITY_X_FRAME_OPTIONS=DENY
# SECURITY_X_CONTENT_TYPE_OPTIONS=nosniff
# SECURITY_REFERRER_POLICY=strict-origin-when-cross-origin

# ==========================================
# CLEANUP CONFIGURATION (Optional)
# ==========================================
# Resource cleanup and timeout settings for containerized deployments
# See: src/lib/config/cleanup.ts for defaults

# Resource Manager Settings
# Timeout for individual cleanup tasks (milliseconds)
# CLEANUP_TASK_TIMEOUT_MS=5000

# Graceful shutdown timeout (milliseconds)
# GRACEFUL_SHUTDOWN_TIMEOUT_MS=10000

# Timeout Settings
# Default timeout for async operations (milliseconds)
# CLEANUP_TIMEOUT_DEFAULT_MS=30000

# Quick timeout for simple operations (milliseconds)
# CLEANUP_TIMEOUT_QUICK_MS=5000

# Long timeout for complex operations (milliseconds)
# CLEANUP_TIMEOUT_LONG_MS=60000

# Abort Controller Settings
# Delay before forcefully aborting stuck operations (milliseconds)
# CLEANUP_ABORT_FORCE_DELAY_MS=1000

# Memory Management Settings
# Interval for memory usage checks (milliseconds)
# CLEANUP_MEMORY_CHECK_INTERVAL_MS=30000

# Threshold for high memory warning (percentage, 0-100)
# CLEANUP_MEMORY_HIGH_USAGE_THRESHOLD=85

# ==========================================
# MEMORY MONITORING CONFIGURATION (Optional)
# ==========================================
# Memory health monitoring thresholds
# See: src/lib/config/health.ts for defaults

# Heap usage warning threshold (percentage of heapTotal)
# MEMORY_HEAP_WARNING_THRESHOLD=80

# Heap usage critical threshold (percentage of heapTotal)
# MEMORY_HEAP_CRITICAL_THRESHOLD=95

# RSS warning threshold in MB
# MEMORY_RSS_WARNING_MB=512

# RSS critical threshold in MB
# MEMORY_RSS_CRITICAL_MB=1024

# External memory warning threshold in MB
# MEMORY_EXTERNAL_WARNING_MB=100

# External memory critical threshold in MB
# MEMORY_EXTERNAL_CRITICAL_MB=256

# ==========================================
# THEME CONFIGURATION (Optional)
# ==========================================
# Theme animation configuration for celebrations and effects

# THEME_ANIMATION_DEFAULT_DURATION_MS=2000
# THEME_ANIMATION_REDUCED_MOTION_DURATION_MS=500
# THEME_STEP_CELEBRATION_DURATION_MS=1500
