# ==========================================
# REQUIRED ENVIRONMENT VARIABLES
# ==========================================

# Application Version (Optional)
# Allows for dynamic versioning in different deployment environments
# If not set, defaults to '1.0.0'
# APP_VERSION=1.0.0

# Supabase Configuration (REQUIRED)
# ⚠️ SECURITY WARNING: See SECURITY.md for proper handling
# These NEXT_PUBLIC_* variables are safe for client-side use
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ⚠️ CRITICAL SECURITY: SUPABASE_SERVICE_ROLE_KEY
# This key bypasses ALL Row Level Security (RLS) policies.
# It grants FULL ADMIN ACCESS to the database.
# 
# SECURITY REQUIREMENTS:
# - NEVER prefix with NEXT_PUBLIC_ (would expose to client bundle)
# - NEVER use in client components or browser code
# - ONLY use in server-side contexts (API routes, server components)
# - See src/lib/db.ts for secure usage patterns
# - See SECURITY.md for full security documentation
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# AI Provider Configuration (at least one REQUIRED)
# Choose ONE of the following or include both for fallback
#
# 🔐 SECURITY BEST PRACTICES for AI Provider Keys:
# - Minimum key length: 32 characters
# - Rotate keys every 90 days
# - Use project-specific keys (not personal keys)
# - Restrict key scopes to minimum required permissions
# - Never commit actual keys to version control
# - Use different keys for dev/staging/production environments
# - Monitor API usage for anomalies
# - Revoke compromised keys immediately
OPENAI_API_KEY=sk-your-openai-api-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Cost Guardrails (REQUIRED)
COST_LIMIT_DAILY=10.0

# Application Configuration (REQUIRED)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==========================================
# OPTIONAL EXPORT INTEGRATIONS
# ==========================================
# Only configure these if you plan to use export features

# Notion Integration
NOTION_API_KEY=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=
NOTION_PARENT_PAGE_ID=

# Trello Integration
TRELLO_API_KEY=
TRELLO_TOKEN=
TRELLO_REDIRECT_URI=

# Google Tasks Integration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_REFRESH_TOKEN=

# GitHub Projects Integration
GITHUB_TOKEN=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=

# Admin Configuration
# ⚠️ SECURITY WARNING: ADMIN_API_KEY
# This key protects administrative endpoints (detailed health checks, etc.)
#
# 🔐 SECURITY REQUIREMENTS:
# - Minimum length: 32 characters
# - Must contain: uppercase, lowercase, numbers, special characters
# - Rotate every 90 days
# - Use different keys for each environment
# - Never log or expose this key in error messages
# - Store securely in your deployment platform's secrets manager
#
# Generate a secure key: openssl rand -base64 32
ADMIN_API_KEY=your-admin-api-key-for-protected-routes

# CORS Configuration (comma-separated list of allowed origins)
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ==========================================
# CONFIGURATION OVERRIDES (Optional)
# ==========================================
# All values have sensible defaults. Only set these if you need to customize.
# See: src/lib/config/environment.ts for all available options

# API Timeouts (milliseconds)
# API_TIMEOUT_DEFAULT=30000
# API_TIMEOUT_QUICK=5000
# API_TIMEOUT_STANDARD=10000
# API_TIMEOUT_LONG=30000

# Rate Limiting
# RATE_LIMIT_DEFAULT_RATE=100
# RATE_LIMIT_DEFAULT_WINDOW=60000
# RATE_LIMIT_TIER_FREE_RATE=10
# RATE_LIMIT_TIER_STANDARD_RATE=100
# RATE_LIMIT_TIER_PREMIUM_RATE=1000

# Retry Configuration
# RETRY_DEFAULT_MAX_RETRIES=3
# RETRY_INITIAL_DELAY=1000
# RETRY_MAX_DELAY=10000
# RETRY_BACKOFF_MULTIPLIER=2
# RETRY_ENABLE_JITTER=true

# Cache Configuration
# CACHE_TTL_SHORT=60000
# CACHE_TTL_STANDARD=300000
# CACHE_TTL_MEDIUM=600000
# CACHE_TTL_LONG=3600000
# CACHE_TTL_AI_RESPONSE=300000
# CACHE_TTL_COST_TRACKING=60000
# CACHE_SIZE_SMALL=50
# CACHE_SIZE_STANDARD=100
# CACHE_SIZE_MEDIUM=200
# CACHE_SIZE_LARGE=1000
# CACHE_SIZE_MAXIMUM=10000
# CACHE_SERVICE_PROMPT_TTL_MS=600000
# CACHE_SERVICE_PROMPT_MAX_SIZE=200
# CACHE_SERVICE_CONFIG_TTL_MS=300000
# CACHE_SERVICE_CONFIG_MAX_SIZE=100
# CACHE_SERVICE_AI_RESPONSE_TTL_MS=300000
# CACHE_SERVICE_AI_RESPONSE_MAX_SIZE=100
# CACHE_SERVICE_COST_TTL_MS=60000
# CACHE_SERVICE_COST_MAX_SIZE=1
# CACHE_CLEANUP_INTERVAL_MS=60000
# CACHE_TRIM_PERCENTAGE=20

# UI Timing (milliseconds)
# UI_FOCUS_DELAY_MS=50
# UI_ANIMATION_FAST=150
# UI_ANIMATION_NORMAL=300
# UI_ANIMATION_SLOW=500
# UI_SCROLL_OFFSET=80
# UI_COPY_FEEDBACK_DURATION_MS=2000
# UI_TOAST_DURATION=3000
# UI_ANIMATION_FAST=200
# UI_ANIMATION_STANDARD=300
# UI_ANIMATION_SLOW=500

# Component Configuration (milliseconds)
# COMPONENT_AUTOSAVE_DELAY_MS=1000
# COMPONENT_AUTOSAVE_HIDE_DELAY_MS=3000
# COMPONENT_AUTOSAVE_DURATION_MS=300
# COMPONENT_AUTOSAVE_PROGRESS_INTERVAL_MS=50
# COMPONENT_LOADING_DEFAULT_TIMEOUT_MS=30000
# COMPONENT_INPUT_VALIDATION_DEBOUNCE_MS=300
# COMPONENT_INPUT_MIN_SEARCH_CHARS=2
# COMPONENT_TOAST_SHORT_DURATION_MS=3000
# COMPONENT_TOAST_NORMAL_DURATION_MS=5000
# COMPONENT_TOAST_LONG_DURATION_MS=8000
# COMPONENT_TOAST_EXIT_DURATION_MS=300
# COMPONENT_BLUEPRINT_GENERATION_DELAY_MS=2000
# COMPONENT_COPY_FEEDBACK_DURATION_MS=2000
# COMPONENT_BUTTON_ANIMATION_DURATION_MS=200

# Validation
# VALIDATION_MAX_ANSWER_LENGTH=5000
# VALIDATION_MIN_IDEA_LENGTH=10
# VALIDATION_MAX_IDEA_LENGTH=10000
# VALIDATION_MAX_REQUEST_BODY_SIZE=1048576

# Pagination Configuration
# Default number of items per page (range: 1-1000)
# PAGINATION_DEFAULT_LIMIT=50
# Maximum allowed items per page (range: 10-1000)
# PAGINATION_MAX_LIMIT=100
# Minimum allowed items per page (range: 1-100)
# PAGINATION_MIN_LIMIT=10
# Default offset for pagination (range: 0-10000)
# PAGINATION_DEFAULT_OFFSET=0

# String Limits Configuration
# Maximum length for title preview (range: 10-200)
# STRING_TITLE_PREVIEW_LENGTH=50
# Length of random portion in idea IDs (range: 4-32)
# STRING_ID_RANDOM_LENGTH=11
# Radix for idea ID generation (range: 2-36)
# STRING_ID_RANDOM_RADIX=36

# AI Service
# AI_DEFAULT_MAX_TOKENS=4000
# AI_DEFAULT_DAILY_COST_LIMIT=10.0
# AI_RESPONSE_CACHE_TTL_MS=300000

# Resilience
# RESILIENCE_RETRY_DEFAULT_MAX_RETRIES=3
# RESILIENCE_CB_DEFAULT_FAILURE_THRESHOLD=5
# RESILIENCE_CB_DEFAULT_RESET_TIMEOUT_MS=60000
# RESILIENCE_TIMEOUT_OPENAI=60000
# RESILIENCE_TIMEOUT_DATABASE=10000

# ==========================================
# SCRIPTS CONFIGURATION (Optional)
# ==========================================
# Configuration for build/audit scripts

# Console Scanner
# SCANNER_NAVIGATION_TIMEOUT=30000
# SCANNER_ASYNC_WAIT_MS=2000

# Lighthouse Auditor
# LIGHTHOUSE_LOW_SCORE_THRESHOLD=70
# LIGHTHOUSE_RTT_MS=40
# LIGHTHOUSE_THROUGHPUT_KBPS=10240
# LIGHTHOUSE_CPU_SLOWDOWN=1
# LIGHTHOUSE_SCREEN_WIDTH=1350
# LIGHTHOUSE_SCREEN_HEIGHT=940
# LIGHTHOUSE_DEVICE_SCALE=1
# CHROME_PATH=/path/to/chrome

# Lighthouse CI
# LHCI_URL=http://localhost:3000
# LHCI_NUMBER_OF_RUNS=1
# LHCI_MIN_PERFORMANCE=70
# LHCI_MIN_ACCESSIBILITY=90
# LHCI_MIN_BEST_PRACTICES=80
# LHCI_MIN_SEO=80

# ==========================================
# LOGGING CONFIGURATION (Optional)
# ==========================================
# Production logging configuration for reliability and debugging
# See: docs/reliability-engineer.md for full documentation

# Log Level (Optional)
# Controls verbosity of application logs
# Valid values: DEBUG, INFO, WARN, ERROR
# Default: INFO (recommended for production)
# Use DEBUG for troubleshooting, WARN/ERROR for quieter operation
# LOG_LEVEL=INFO

# Structured Logging (Recommended for production)
# When enabled, logs are output as JSON for log aggregation services
# Useful for: CloudWatch, Datadog, Splunk, ELK stack
# STRUCTURED_LOGGING=true

# Emergency Debug Mode (Use sparingly)
# Enables debug-level logs in production for troubleshooting
# ⚠️ WARNING: Only enable temporarily during incident response
# Set to 'true' then set back to 'false' after debugging
# ENABLE_DEBUG_LOGS=false

# Build Log Suppression
# Suppresses non-error logs during build to improve Lighthouse scores
# Automatically set during npm run build
# SUPPRESS_BUILD_LOGS=true

# ==========================================
# SECURITY CONFIGURATION (Optional)
# ==========================================
# Security headers configuration for production deployments
# See: src/lib/config/constants.ts for SECURITY_CONFIG defaults

# HSTS (HTTP Strict Transport Security)
# Maximum age in seconds (default: 31536000 = 1 year)
# SECURITY_HSTS_MAX_AGE=31536000

# Include subdomains in HSTS (default: true)
# SECURITY_HSTS_INCLUDE_SUBDOMAINS=true

# Enable HSTS preload list submission (default: true)
# SECURITY_HSTS_PRELOAD=true