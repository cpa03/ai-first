# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Next.js
.next/
out/
dist/

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Vercel
.vercel

# OpenNext Cloudflare build output
.open-next/
.wrangler/

# TypeScript
*.tsbuildinfo
# next-env.d.ts should be committed - see Next.js docs

# SWC (Next.js compiler cache)
.swc/
.next/cache/

# IDE
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
.idea/

# OS
.DS_Store
Thumbs.db

# Logs
*.log
task_plan.md

# Generated reports (by npm scripts)
console-scan-report.json
lighthouse-report.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# nyc test coverage
.nyc_output

# Dependency directories
jspm_packages/

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# pnpm lock file (we use npm)
pnpm-lock.yaml

# parcel-bundler cache (https://parceljs.org/)
.cache
.parcel-cache

# nuxt.js build output
.nuxt

# vuepress build output
.vuepress/dist

# Serverless directories
.serverless

# FuseBox cache
.fusebox/

# DynamoDB Local files
.dynamodb/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
# Git worktrees
.worktrees/

# Agent temporary directories
# .Jules/ - Bolt AI temporary files
.Jules/
# .jules/ - Bolt AI temporary files (lowercase variant)
.jules/
# .omo/ - Ralph loop temporary files
.omo/
# .sisyphus/ is for Sisyphus agent state persistence
.sisyphus/

# OpenCode CLI - ignore auto-generated node_modules
.opencode/node_modules/
.opencode/package-lock.json

# Codegraph - generated database
.codegraph/

# Archive backups (should not be committed)
docs/archive/*.gz
docs/archive/*.zip
docs/archive/*.tar
docs/archive/*.tar.gz
# Note: docs/archive/README.md is intentionally tracked for documentation

# Temporary agent reports (auto-generated, should not be committed)
# Case-insensitive patterns for audit reports
*[Bb][Rr][Oo][Cc][Uu][Ll][Aa]*[Aa][Uu][Dd][Ii][Tt]*.md
*[Bb][Rr][Oo][Cc][Uu][Ll][Aa]*[Vv][Ee][Rr][Ii][Ff][Ii][Cc][Aa][Tt][Ii][Oo][Nn]*.md
*[Bb][Rr][Oo][Cc][Uu][Ll][Aa]*[Ss][Cc][Aa][Nn]*[Rr][Ee][Pp][Oo][Rr][Tt]*.md
*[Cc][Oo][Dd][Ee][Bb][Aa][Ss][Ee]*[Hh][Ee][Aa][Ll][Tt][Hh]*[Cc][Hh][Ee][Cc][Kk]*.md
*[Rr][Ee][Pp][Oo][Kk][Ee][Ee][Pp][Ee][Rr]*[Mm][Aa][Ii][Nn][Tt][Ee][Nn][Aa][Nn][Cc][Ee]*.md
*[Aa][Uu][Dd][Ii][Tt]*[Rr][Ee][Pp][Oo][Rr][Tt]*.md
*[Hh][Ee][Aa][Ll][Tt][Hh]*[Cc][Hh][Ee][Cc][Kk]*.md
