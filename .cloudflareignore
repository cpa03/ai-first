tests/
coverage/
*.test.*
*.spec.*
__tests__/
__mocks__/
*.snap

# Development files
.env*
.env.local
.env.development.local
.env.test.local
.env.production.local
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.DS_Store
Thumbs.db

